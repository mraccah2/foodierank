// iOS Google Maps SDK key for the embedded map picker.
//
// Copy this file to `Secrets.xcconfig` (gitignored) and fill in your iOS
// Maps API key. It is surfaced to the app via the `GMSApiKey` entry in
// Info.plist and consumed in AppDelegate.swift by `GMSServices.provideAPIKey`.
//
// This mirrors the Android pattern (MAPS_API_KEY in android/local.properties).
// In CI, the value is written from the `IOS_MAPS_API_KEY` GitHub secret instead
// of committing the key. Never commit the real key.
GOOGLE_MAPS_IOS_API_KEY = YOUR_IOS_GOOGLE_MAPS_API_KEY
