# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/key.properties

# Build outputs anywhere in the tree (not just the repo root)
**/build/

# Editor/tooling backups
*.backup

# Never commit Firebase admin SDK / service-account keys
*service-account*.json
*-adminsdk-*.json
*service_account*.json

# Local build-time secrets (API keys injected via --dart-define-from-file).
/ios/Flutter/Secrets.xcconfig
# The *.example templates ARE committed; the real files are not.
/dart_defines.json
/android/local.properties
